# ──────────────────────────────────────────────────────────────────────────
# Mantle Edge — environment configuration
# Copy this file to `.env` in the monorepo root and fill in the values.
# Never commit your real `.env` file.
# ──────────────────────────────────────────────────────────────────────────

# --- Mantle network -----------------------------------------------------
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000

# --- Agent wallet ---------------------------------------------------------
# Private key (no 0x prefix or with it, both are accepted) of the wallet the
# agent uses to sign on-chain transactions (DEX swaps, identity registration).
# NEVER use a wallet that holds more funds than you are willing to risk.
AGENT_PRIVATE_KEY=

# --- Bybit (CEX execution + market data) -----------------------------------
BYBIT_API_KEY=
BYBIT_SECRET=
# Set to "true" to use the Bybit testnet REST endpoints instead of mainnet.
BYBIT_TESTNET=false

# --- LLM provider (decision reasoning / summaries) --------------------------
# Provide either an OpenAI or an Anthropic key. If both are set, Anthropic
# is preferred. Leave both empty to fall back to the built-in rule-based
# strategy only.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Anthropic model used by the multi-agent system's MarketAnalystAgent for
# market reasoning. Defaults to a fast/cheap Haiku model.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Dashboard (Next.js, public) --------------------------------------------
# Address of the agent's on-chain wallet, shown on the public dashboard.
NEXT_PUBLIC_AGENT_ADDRESS=
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.mantle.xyz
NEXT_PUBLIC_MANTLE_CHAIN_ID=5000

# --- Trading configuration ---------------------------------------------------
# Trading pair the agent watches, in BASE/QUOTE form.
TRADING_PAIR=MNT/USDT
# Bybit symbol for the same pair (no slash).
BYBIT_SYMBOL=MNTUSDT
# How often the agent runs its decision loop, in milliseconds.
AGENT_POLL_INTERVAL_MS=60000
# Maximum notional (in quote currency) the agent will allocate per trade.
MAX_TRADE_SIZE_USD=25
# Minimum confidence (0-1) a strategy decision needs before the executor
# will act on it.
MIN_CONFIDENCE=0.6
# Where the agent should execute trades: "dex" (Mantle on-chain) or "cex" (Bybit).
EXECUTION_VENUE=dex

# --- ERC-8004 agent identity --------------------------------------------------
# Address of a deployed AgentIdentityRegistry contract (see packages/contracts).
# Leave empty to skip on-chain identity registration.
AGENT_IDENTITY_REGISTRY_ADDRESS=
# Off-chain metadata URI describing this agent (IPFS/HTTPS), used when
# registering the agent identity.
AGENT_METADATA_URI=
# Address of a deployed LogRegistry contract (see packages/contracts), used by
# the multi-agent ExecutorAgent to emit an on-chain audit trail of its actions.
# Leave empty to skip on-chain action logging.
LOG_REGISTRY_ADDRESS=

# --- Storage -------------------------------------------------------------------
# Directory (relative to the monorepo root) where the agent writes its
# trade log / decision history JSON files and SQLite database. The dashboard
# reads from here too.
DATA_DIR=data

# --- Multi-agent trading system (apps/agent/src/multiAgentIndex.ts) ---------
# Starting paper-trading equity (USD) seeded into the SQLite portfolio ledger.
STARTING_EQUITY_USD=1000
# Maximum fraction of equity the RiskManagerAgent will allocate to a single
# new position (0.2 = 20%).
RISK_MAX_POSITION_PCT=0.2
# Stop-loss distance from entry price, as a fraction (0.05 = -5%).
RISK_STOP_LOSS_PCT=0.05
# Daily loss limit, as a fraction of the equity at the start of the UTC day
# (0.15 = -15%). Once breached, no new positions are opened until the next day.
RISK_DAILY_LOSS_LIMIT_PCT=0.15
# How often the orchestrator runs the Analyst -> RiskManager -> Executor ->
# Reporter pipeline, in milliseconds. Defaults to 5 minutes.
ORCHESTRATOR_CYCLE_MS=300000
# How often the ReporterAgent rewrites apps/dashboard/public/data/agent-feed.json
# independently of the main cycle, in milliseconds. Defaults to 60 seconds.
REPORTER_INTERVAL_MS=60000
