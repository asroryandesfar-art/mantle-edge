{
  "name": "@mantle-edge/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "hardhat compile",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:mantle": "hardhat run scripts/deploy.ts --network mantle",
    "deploy:mantleSepolia": "hardhat run scripts/deploy.ts --network mantleSepolia",
    "deploy:agentContracts": "hardhat run scripts/deployAgentContracts.ts --network mantle",
    "deploy:agentContracts:mantleSepolia": "hardhat run scripts/deployAgentContracts.ts --network mantleSepolia",
    "deploy:all:mantle": "hardhat run scripts/deployAll.ts --network mantle",
    "deploy:all:mantleSepolia": "hardhat run scripts/deployAll.ts --network mantleSepolia",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "hardhat clean && rimraf cache artifacts typechain-types"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.7",
    "chai": "^4.5.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.17",
    "hardhat-gas-reporter": "^1.0.10",
    "rimraf": "^6.0.1",
    "solidity-coverage": "^0.8.14",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.6.3"
  }
}
